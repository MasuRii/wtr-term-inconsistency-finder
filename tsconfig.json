{
	"compilerOptions": {
		"target": "ES2021",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowJs": false,
		"checkJs": false,
		"strict": false,
		"noImplicitAny": false,
		"noEmit": true,
		"isolatedModules": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node"]
	},
	"include": ["src/**/*", "src/types/**/*.d.ts", "config/**/*.ts", "scripts/**/*.ts", "*.config.ts"]
}
